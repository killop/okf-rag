/target/
/dist/
/.cache/
/.mcp_data/
/.venv/
/reports/
/.daemon-*/

# Keep the project-local Codex template, ignore machine-specific config.
/.codex/*
!/.codex/
!/.codex/config.toml.example

# OKF-RAG runtime state is derived and can be rebuilt.
/.okf-rag/

# Generated benchmark/vector-store artifacts.
/data/bench-runs/
/data/benchmarks/
/data/recall-runs/
/data/zvec-generic-demo/
/data/zvec-minilm-demo/
/data/beir-zvec/
/data/real-okf-knowledge-memory/
/data/knowledge-memory-system-proof/
/data/knowledge-memory-zvec-sample/
/data/knowledge-memory-zvec-sample-check/
/data/mempalace-zvec-runs/
/data/okf-memory-benchmark/
/data/ork-rag-smoke/

# OKF-RAG truth/demo workspace is intentional project content.
# Do not ignore okf-rag-workspace/.
/okf-rag-workspace/bin/*
!/okf-rag-workspace/bin/README.md
/okf-rag-workspace/raw/*
!/okf-rag-workspace/raw/.gitkeep

*.pyc
__pycache__/
